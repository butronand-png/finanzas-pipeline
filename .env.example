# Copia este archivo a .env (ignorado por git) y define los valores reales.
# - docker compose lee .env automáticamente para levantar Postgres.
# - src/db.py también lee .env (parser propio, sin dependencias).

# Password del Postgres local (contenedor finanzas-pg)
POSTGRES_PASSWORD=cambia_este_password

# Conexión desde Python (src/db.py). Host/puerto/db tienen estos defaults
# en el código; user y password son obligatorios.
DB_HOST=localhost
DB_PORT=5434
DB_NAME=finanzas
DB_USER=finanzas
DB_PASSWORD=cambia_este_password
